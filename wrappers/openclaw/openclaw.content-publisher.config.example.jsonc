{
  // Merge this snippet into your OpenClaw config.
  "contentPublisher": {
    "enabled": true,
    "baseUrl": "https://xsai5.xyz",
    "apiToken": "replace-with-real-token",
    "lanBaseUrl": "http://192.168.2.7:3091",
    "defaultMode": "draft",
    "skillPath": "./skills/nexai-content-publisher",
    "workflow": [
      "context",
      "media-upload-if-needed",
      "validate",
      "draft-create-or-update",
      "publish-on-explicit-request"
    ]
  }
}
